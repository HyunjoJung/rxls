{
  "default_include_tiers": [
    "S"
  ],
  "provenance_classes": {
    "issue_or_bug_submission": "issue or bug submission whose artifact-level redistribution grant has not been independently verified",
    "project_authored_fixture": "fixture with repository evidence tying it to project-authored examples, generators, or feature tests",
    "third_party_or_unreviewed_fixture": "known third-party data or a fixture whose original authorship remains unreviewed",
    "unreviewed_upstream_fixture": "repository-distributed fixture without sufficient file-level authorship evidence"
  },
  "rights_policy": {
    "active_content": {
      "handling": "quarantine; never include in a shareable render run without an explicit Q-tier opt-in",
      "tier": "Q"
    },
    "embedded_media": {
      "handling": "internal-only until every bundled asset has a documented redistribution basis",
      "tier": "U"
    },
    "external_relationship": {
      "handling": "internal-only; render oracles must run with networking disabled",
      "tier": "U"
    },
    "invalid_or_encrypted_package": {
      "handling": "quarantine; do not send to a renderer outside an isolated negative-test lane",
      "tier": "Q"
    }
  },
  "rights_tiers": {
    "Q": "quarantine: active, encrypted, malformed, executable, or otherwise unsafe/uncertain content",
    "S": "shareable: selected upstream fixture scope is covered by the declared license and no package-level risk was detected",
    "U": "internal-only: usable for local evaluation but media, external references, or provenance still require review"
  },
